<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Azure Horizon | Voyage Beyond Limits</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>
    <header>
        <a href="/" class="logo">AZURE HORIZON</a>
        <nav>
            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/destinations">Destinations</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact</a></li>
                
                <% if (user) { %>
                    <% if (user.role === 'admin') { %>
                        <li><a href="/admin/dashboard" style="color: var(--primary); font-weight: 700;"><i class="fas fa-gauge-high"></i> Dashboard</a></li>
                    <% } %>
                    <li style="border-left: 1px solid var(--glass-border); padding-left: 20px; display: flex; align-items: center; gap: 10px;">
                        <span style="font-size: 0.85rem; color: var(--text-muted);"><%= user.username %></span>
                        <a href="/logout" style="font-size: 0.8rem; background: rgba(245, 87, 108, 0.1); color: var(--accent-alt); padding: 5px 15px; border-radius: 50px; border: 1px solid rgba(245, 87, 108, 0.2);">Logout</a>
                    </li>
                <% } else { %>
                    <li><a href="/login">Login</a></li>
                    <li><a href="/register" class="card-btn" style="padding: 10px 25px; border-radius: 50px; background: rgba(0, 242, 254, 0.1);">Join Horizon</a></li>
                <% } %>
            </ul>
        </nav>
    </header>
