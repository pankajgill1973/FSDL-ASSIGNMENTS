<%- include('../partials/header') %>

<main style="padding-top: 120px;">
    <section>
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4rem;">
            <h1 class="section-title" style="margin-bottom: 0; text-align: left;">Admin Control Panel</h1>
            <div style="background: var(--bg-card); padding: 0.75rem 1.5rem; border-radius: 50px; border: 1px solid var(--glass-border); font-size: 0.9rem; color: var(--text-muted);">
                Viewing All Inquiries: <span style="color: var(--primary); font-weight: 700;"><%= bookings.length %></span>
            </div>
        </div>

        <div style="overflow-x: auto; background: var(--bg-card); padding: 2rem; border-radius: 32px; border: 1px solid var(--glass-border); backdrop-filter: blur(20px);">
            <table style="width: 100%; border-collapse: separate; border-spacing: 0 1rem; text-align: left;">
                <thead>
                    <tr style="color: var(--text-muted); text-transform: uppercase; font-size: 0.8rem; letter-spacing: 1px;">
                        <th style="padding: 1rem 1.5rem;">Expedition</th>
                        <th style="padding: 1rem 1.5rem;">Inquirer (User)</th>
                        <th style="padding: 1rem 1.5rem;">Contact Email</th>
                        <th style="padding: 1rem 1.5rem;">Departure Date</th>
                        <th style="padding: 1rem 1.5rem;">Inquiry Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% bookings.forEach(booking => { %>
                        <tr style="background: rgba(255,255,255,0.02); border-radius: 12px; transition: transform 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.05)'" onmouseout="this.style.background='rgba(255,255,255,0.02)'">
                            <td style="padding: 1.5rem; border-radius: 16px 0 0 16px;">
                                <div style="display: flex; align-items: center; gap: 15px;">
                                    <img src="<%= booking.destinationId.image %>" style="width: 45px; height: 45px; object-fit: cover; border-radius: 10px; border: 1px solid var(--glass-border);" alt="Dest">
                                    <span style="font-weight: 700; color: #fff;"><%= booking.destinationId.name %></span>
                                </div>
                            </td>
                            <td style="padding: 1.5rem;">
                                <div style="font-weight: 600; color: #fff;"><%= booking.userName %></div>
                                <div style="font-size: 0.75rem; color: var(--text-muted);">ID: <%= booking.userId.username %></div>
                            </td>
                            <td style="padding: 1.5rem;"><%= booking.email %></td>
                            <td style="padding: 1.5rem; font-weight: 600;"><%= booking.travelDate.toLocaleDateString() %></td>
                            <td style="padding: 1.5rem; border-radius: 0 16px 16px 0;">
                                <span style="background: rgba(0, 242, 254, 0.1); color: var(--primary); padding: 4px 12px; border-radius: 50px; font-size: 0.75rem; font-weight: 700; border: 1px solid rgba(0, 242, 254, 0.2);">
                                    <%= booking.status %>
                                </span>
                            </td>
                        </tr>
                    <% }) %>

                    <% if (bookings.length === 0) { %>
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 5rem; color: var(--text-muted);">
                                <i class="fas fa-folder-open" style="font-size: 2rem; margin-bottom: 2rem; display: block; opacity: 0.3;"></i>
                                No inquiries have been logged yet. Check your cosmic frequency.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </section>
</main>

<%- include('../partials/footer') %>
