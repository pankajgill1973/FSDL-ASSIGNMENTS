<%- include('partials/header') %>

<main style="padding-top: 100px;">
    <section>
        <div class="booking-container" style="max-width: 450px;">
            <h2 class="section-title" style="font-size: 2rem; margin-bottom: 2rem;">Welcome Back</h2>
            
            <% if (error) { %>
                <div style="background: rgba(245, 87, 108, 0.1); border: 1px solid var(--accent-alt); color: var(--accent-alt); padding: 1rem; border-radius: 12px; margin-bottom: 2rem; font-size: 0.9rem; text-align: center;">
                    <i class="fas fa-exclamation-circle" style="margin-right: 8px;"></i> <%= error %>
                </div>
            <% } %>

            <form action="/login" method="POST">
                <div class="form-group">
                    <label for="email">Email Address</label>
                    <input type="email" id="email" name="email" required placeholder="name@domain.com">
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" required placeholder="••••••••">
                </div>
                
                <button type="submit" class="submit-btn" style="margin-top: 1rem;">Authenticate <i class="fas fa-lock" style="margin-left: 10px;"></i></button>
            </form>

            <div style="margin-top: 2rem; text-align: center; color: var(--text-muted); font-size: 0.9rem;">
                New to the horizon? <a href="/register" style="color: var(--primary); font-weight: 600;">Create an Account</a>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer') %>
