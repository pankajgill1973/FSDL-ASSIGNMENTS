<%- include('partials/header') %>

    <main style="padding-top: 100px;">
        <section class="hero" style="height: 60vh; background: linear-gradient(rgba(2, 6, 23, 0.8), rgba(2, 6, 23, 0.8)), url('https://images.unsplash.com/photo-1524492459463-500e2b380482?auto=format&fit=crop&w=1920&q=80');">
            <h1>Our <span class="logo">Vision</span></h1>
            <p>At Azure Horizon, we don't just plan trips; we architect life-defining moments. Our mission is to redefine luxury through the lens of authenticity and sustainability.</p>
        </section>

        <section>
            <div style="max-width: 1000px; margin: 0 auto; text-align: center;">
                <h2 class="section-title">Luxury Without Limits</h2>
                <div class="about-content" style="text-align: left;">
                    <div class="about-text">
                        <p style="font-size: 1.15rem; color: var(--text-muted); margin-bottom: 2rem;">
                            Born from a desire to merge the timeless heritage of Indian hospitality with the sleek efficiency of modern travel technology, **Azure Horizon** stands at the pinnacle of bespoke tourism.
                        </p>
                        <p style="font-size: 1.15rem; color: var(--text-muted); margin-bottom: 2rem;">
                            We specialize in the "Unseen India" and "Hidden Europe," providing our explorers with access to private estates, secret festivals, and panoramic vistas that remain off the standard maps.
                        </p>
                    </div>
                    <div class="about-image">
                        <img src="https://images.unsplash.com/photo-1506197603052-3cc9c3a201bd?auto=format&fit=crop&w=800&q=80" alt="Luxury Travel">
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-top: 6rem;">
                    <div style="background: var(--bg-card); padding: 3rem 2rem; border-radius: 24px; border: 1px solid var(--glass-border);">
                        <h3 style="color: var(--primary); font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem;">12+</h3>
                        <p style="text-transform: uppercase; letter-spacing: 2px; font-size: 0.8rem; color: var(--text-muted);">Years of Craft</p>
                    </div>
                    <div style="background: var(--bg-card); padding: 3rem 2rem; border-radius: 24px; border: 1px solid var(--glass-border);">
                        <h3 style="color: var(--primary); font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem;">8.5k</h3>
                        <p style="text-transform: uppercase; letter-spacing: 2px; font-size: 0.8rem; color: var(--text-muted);">Global Explorers</p>
                    </div>
                    <div style="background: var(--bg-card); padding: 3rem 2rem; border-radius: 24px; border: 1px solid var(--glass-border);">
                        <h3 style="color: var(--primary); font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem;">64</h3>
                        <p style="text-transform: uppercase; letter-spacing: 2px; font-size: 0.8rem; color: var(--text-muted);">Curated Portfolios</p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
