<%- include('partials/header') %>

    <main style="padding-top: 100px;">
        <section>
            <h2 class="section-title">Connect with Our Experts</h2>
            <div class="contact-container" style="max-width: 1000px;">
                <div style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 4rem;">
                    <div style="background: rgba(255,255,255,0.02); padding: 2rem; border-radius: 20px; border: 1px solid var(--glass-border);">
                        <h3 style="color: var(--primary); font-size: 1.5rem; margin-bottom: 2rem;">Studio Azure</h3>
                        
                        <div style="margin-bottom: 2rem;">
                            <p style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; margin-bottom: 0.5rem; letter-spacing: 1px;">Global HQ</p>
                            <p style="font-weight: 500;">Block E, Inner Circle, CP<br>New Delhi, 110001, India</p>
                        </div>

                        <div style="margin-bottom: 2rem;">
                            <p style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; margin-bottom: 0.5rem; letter-spacing: 1px;">Correspondence</p>
                            <p style="font-weight: 500;">concierge@azurehorizon.travel</p>
                        </div>

                        <div>
                            <p style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; margin-bottom: 0.5rem; letter-spacing: 1px;">Direct Line</p>
                            <p style="font-size: 1.25rem; font-weight: 800; color: #fff;">+91 9999 000 888</p>
                        </div>
                    </div>
                    
                    <div>
                        <h3 style="font-size: 1.5rem; margin-bottom: 2rem;">Tell us about your <span style="color: var(--primary);">dream trip</span></h3>
                        <form action="#" method="POST">
                            <div class="form-group">
                                <label>Your Identity</label>
                                <input type="text" placeholder="Legal Name" required>
                            </div>
                            <div class="form-group">
                                <label>Electronic Mail</label>
                                <input type="email" placeholder="you@domain.com" required>
                            </div>
                            <div class="form-group">
                                <label>Visions & Requirements</label>
                                <textarea placeholder="Describe the experiences you are looking for..." style="height: 120px;"></textarea>
                            </div>
                            <button type="submit" class="submit-btn">Initiate Connection</button>
                        </form>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
