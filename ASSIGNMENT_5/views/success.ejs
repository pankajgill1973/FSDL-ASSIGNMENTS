<%- include('partials/header') %>

    <main style="padding-top: 100px;">
        <section style="height: 70vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center;">
            <div class="success-icon"><i class="fas fa-check-circle"></i></div>
            <h1 style="font-size: 3rem; font-weight: 800; margin-bottom: 1.5rem; background: linear-gradient(to right, #fff, var(--primary)); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">
                <%= message %>
            </h1>
            <p style="color: var(--text-muted); font-size: 1.25rem; margin-bottom: 3rem; max-width: 600px;">
                Your reservation has been logged into our celestial registry. An Azure Horizon concierge will reach out via encrypted mail within the next 24 hours.
            </p>
            <a href="/" class="cta-button">Back to Earth</a>
        </section>
    </main>

    <%- include('partials/footer') %>
