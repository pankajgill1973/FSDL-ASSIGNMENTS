<%- include('partials/header') %>

    <main style="padding-top: 100px;">
        <section>
            <h2 class="section-title">Secure Your Expedition</h2>
            <div class="booking-container">
                <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--glass-border);">
                    <div>
                        <p style="text-transform: uppercase; font-size: 0.75rem; letter-spacing: 2px; color: var(--primary); margin-bottom: 0.5rem;">Reservation For</p>
                        <h3 style="font-size: 2rem; font-weight: 800;"><%= destination.name %></h3>
                    </div>
                    <div style="text-align: right;">
                        <p style="font-size: 0.85rem; color: var(--text-muted);">Package Price</p>
                        <p style="font-size: 1.5rem; font-weight: 800; color: var(--primary);">$<%= destination.price %></p>
                    </div>
                </div>

                <form action="/book" method="POST">
                    <input type="hidden" name="destinationId" value="<%= destination._id %>">

                    <div class="form-group">
                        <label for="userName">Full Name</label>
                        <input type="text" id="userName" name="userName" required placeholder="Enter your full name">
                    </div>

                    <div class="form-group">
                        <label for="email">Email Address</label>
                        <input type="email" id="email" name="email" required placeholder="you@example.com">
                    </div>

                    <div class="form-group">
                        <label for="travelDate">Departure Date</label>
                        <input type="date" id="travelDate" name="travelDate" required>
                    </div>

                    <button type="submit" class="submit-btn" style="margin-top: 1rem;">Complete Booking <i class="fas fa-arrow-right" style="margin-left: 10px;"></i></button>
                </form>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
